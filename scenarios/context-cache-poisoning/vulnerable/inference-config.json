{
  "inference_server": {
    "model": "llama-3-70b",
    "host": "0.0.0.0",
    "port": 8000,
    "max_concurrent_requests": 256
  },
  "cache": {
    "enabled": true,
    "type": "prefix_cache",
    "shared_across_tenants": true,
    "tenant_isolation": false,
    "cache_key_includes_tenant_id": false,
    "max_cache_size_gb": 32
  },
  "multi_tenancy": {
    "enabled": true,
    "tenant_header": "X-Tenant-ID",
    "isolate_kv_cache": false
  }
}
